---
import PageLayout from '../../layouts/PageLayout.astro'
import { blogPosts } from '../../data/blogPosts'
import { ui } from '../../i18n/ui'
import type { Locale } from '../../i18n/locale'

interface Props {
  locale?: Locale
}

const { locale = 'en' } = Astro.props as Props
const t = ui(locale)

// Each locale's blog lists only its own-language posts. An article is authored
// in both languages (en → /blog, ru → /ru/blog), so there's no cross-locale mixing.
const posts = blogPosts.filter((p) => p.lang === locale)
const fmt = (iso: string) =>
  new Date(iso).toLocaleDateString(locale === 'ru' ? 'ru-RU' : 'en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  })
---

<PageLayout
  locale={locale}
  title={`${t.blogTitle} - Alisie`}
  description={t.blogMetaDescription}
  path="/blog"
>
  <h1
    class="inline-block text-4xl md:text-5xl font-bold py-2
      bg-gradient-to-b from-[var(--color-tint-start)] to-[var(--color-tint-end)]
      bg-clip-text text-transparent"
  >
    {t.blogTitle}
  </h1>
  <p class="text-lg text-color opacity-70 mt-2">{t.blogIntro}</p>

  <div class="mt-10 flex flex-col gap-8">
    {
      posts.map((post) => (
        <a href={post.lang === 'ru' ? `/ru/blog/${post.slug}` : `/blog/${post.slug}`} class="blogCard block group">
          <h2 class="text-xl md:text-2xl font-semibold text-color group-hover:text-[var(--color-tint-start)] transition-colors">
            {post.title}
          </h2>
          <p class="text-sm text-color opacity-50 mt-1">{fmt(post.pubDate)}</p>
          <p class="text-base text-color opacity-70 mt-2">{post.description}</p>
        </a>
      ))
    }
    {posts.length === 0 && <p class="text-color opacity-60">{t.blogEmpty}</p>}
  </div>
</PageLayout>
