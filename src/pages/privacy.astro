---
import PageLayout from '../layouts/PageLayout.astro'
import PrivacyContent from '../app/PrivacyContent'
import { ui } from '../i18n/ui'

const locale = 'en'
const t = ui(locale)
const title = `${t.privacyPolicyTitle} - Alisie`
---

<PageLayout
  locale={locale}
  title={title}
  description={t.privacyMetaDescription}
  path="/privacy"
>
  <PrivacyContent locale={locale} />
</PageLayout>
