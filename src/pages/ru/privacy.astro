---
import PageLayout from '../../layouts/PageLayout.astro'
import PrivacyContent from '../../app/PrivacyContent'
import { ui } from '../../i18n/ui'

const locale = 'ru'
const t = ui(locale)
const title = `${t.privacyPolicyTitle} - Alisie`
---

<PageLayout
  locale={locale}
  title={title}
  description={t.metaDescription}
  path="/privacy"
>
  <PrivacyContent locale={locale} />
</PageLayout>
