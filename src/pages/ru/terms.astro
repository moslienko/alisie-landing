---
import BaseLayout from '../../layouts/BaseLayout.astro'
import TermsContent from '../../app/TermsContent'
import { ui } from '../../i18n/ui'

const locale = 'ru'
const t = ui(locale)
const title = `${t.termsTitle} - Alisie`
---

<BaseLayout
  locale={locale}
  title={title}
  description={t.metaDescription}
  path="/terms"
>
  <TermsContent locale={locale} client:idle />
</BaseLayout>
