---
import BaseLayout from './BaseLayout.astro'
import PageHeader from './PageHeader.astro'
import ThemeToggle from '../components/ThemeToggle/ThemeToggle'
import type { Locale } from '../i18n/locale'

interface Props {
  locale: Locale
  title: string
  description: string
  path: string
  hideLangSwitcher?: boolean
}

const { locale, title, description, path, hideLangSwitcher = false } = Astro.props
---

<BaseLayout locale={locale} title={title} description={description} path={path}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <PageHeader locale={locale} hideLangSwitcher={hideLangSwitcher} />
    <main class="mt-12">
      <slot />
    </main>
  </div>
  <ThemeToggle locale={locale} client:idle />
</BaseLayout>
