---
import BaseLayout from './BaseLayout.astro'
import LegalHeader from './LegalHeader.astro'
import type { Locale } from '../i18n/locale'

interface Props {
  locale: Locale
  title: string
  description: string
  path: string
}

const { locale, title, description, path } = Astro.props
---

<BaseLayout locale={locale} title={title} description={description} path={path}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <LegalHeader locale={locale} />
    <main class="mt-12">
      <slot />
    </main>
  </div>
</BaseLayout>
