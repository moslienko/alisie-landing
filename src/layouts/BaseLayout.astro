---
import "../index.css";
import { ClientRouter } from "astro:transitions";
import { APP_STORE_URL } from "../config/appStats";

export interface Props {
  /** Page locale. */
  locale: "en" | "ru";
  /** Document <title>. */
  title: string;
  /** Meta description. */
  description: string;
  /** Locale-neutral path (no /ru prefix, leading slash), e.g. "/", "/privacy". */
  path: string;
  /**
   * Set when the page has no translated twin (e.g. an English-only blog post).
   * Suppresses the hreflang / og:locale:alternate links so we don't point Google
   * at a non-existent /ru URL.
   */
  noAlternates?: boolean;
}

const { locale, title, description, path, noAlternates = false } = Astro.props;

const SITE = "https://alisie.app";

// Build canonical + hreflang alternates from the locale-neutral path.
const enHref = path === "/" ? `${SITE}/` : `${SITE}${path}`;
const ruHref = path === "/" ? `${SITE}/ru` : `${SITE}/ru${path}`;
const canonical = locale === "ru" ? ruHref : enHref;
const ogLocale = locale === "ru" ? "ru_RU" : "en_US";
const ogLocaleAlt = locale === "ru" ? "en_US" : "ru_RU";
const ogImage = locale === "ru" ? `${SITE}/og-ru.png` : `${SITE}/og-en.png`;

const appSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: locale === "ru" ? "Alisie - Дневник снов" : "Alisie - Dream Diary",
  description,
  applicationCategory: "LifestyleApplication",
  operatingSystem: "iOS",
  url: canonical,
  image: ogImage,
  inLanguage: locale,
  downloadUrl: APP_STORE_URL,
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
};

const siteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Alisie",
  url: SITE,
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <ClientRouter />
    <link rel="preload" as="image" href="/app_icon_192.png" />
    <!-- iOS Safari Smart App Banner - native "Open in App" prompt -->
    <meta name="apple-itunes-app" content="app-id=1485091289" />

    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="dream journal, dream diary, lucid dreaming, dream tracker, iOS, iPhone, iPad, Alisie"
    />
    <link rel="canonical" href={canonical} />

    <!-- Language alternates (omitted for pages with no translated twin) -->
    {
      !noAlternates && (
        <>
          <link rel="alternate" hreflang="en" href={enHref} />
          <link rel="alternate" hreflang="ru" href={ruHref} />
          <link rel="alternate" hreflang="x-default" href={enHref} />
        </>
      )
    }

    <!-- Open Graph (Facebook, Telegram, VK, LinkedIn) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Alisie" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Alisie — a private dream journal" />
    <meta property="og:locale" content={ogLocale} />
    {
      !noAlternates && (
        <meta property="og:locale:alternate" content={ogLocaleAlt} />
      )
    }

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured data: SoftwareApplication (mobile app rich snippets) -->
    <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(siteSchema)} />

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#030303" />
    <link
      rel="preload"
      href="/fonts/sora.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <title>{title}</title>
    <!-- Set the theme before first paint to avoid a flash of the wrong theme.
         Re-runs after each View Transition swap so navigation never flashes. -->
    <script is:inline>
      function currentTheme() {
        try {
          return localStorage.getItem("theme") === "light" ? "light" : "dark";
        } catch (e) {
          return "dark";
        }
      }
      function applyTheme() {
        var theme = currentTheme();
        document.documentElement.classList.remove("theme-light", "theme-dark");
        document.documentElement.classList.add("theme-" + theme);
        var meta = document.querySelector('meta[name="theme-color"]');
        if (meta) {
          meta.setAttribute(
            "content",
            theme === "light" ? "#f7f6fb" : "#030303",
          );
        }
      }
      applyTheme();
      document.addEventListener("astro:after-swap", applyTheme);
    </script>
  </head>
  <body>
    <!-- Yandex.Metrika counter -->
    <script type="text/javascript" is:inline>
      function loadMetrika() {
        (function (m, e, t, r, i, k, a) {
          m[i] =
            m[i] ||
            function () {
              (m[i].a = m[i].a || []).push(arguments);
            };
          m[i].l = 1 * new Date();
          for (var j = 0; j < document.scripts.length; j++) {
            if (document.scripts[j].src === r) {
              return;
            }
          }
          ((k = e.createElement(t)),
            (a = e.getElementsByTagName(t)[0]),
            (k.async = 1),
            (k.src = r),
            a.parentNode.insertBefore(k, a));
        })(
          window,
          document,
          "script",
          "https://mc.yandex.ru/metrika/tag.js?id=110118475",
          "ym",
        );

        ym(110118475, "init", {
          ssr: true,
          clickmap: true,
          ecommerce: "dataLayer",
          referrer: document.referrer,
          url: location.href,
          accurateTrackBounce: true,
          trackLinks: true,
        });
      }

      function deferMetrika() {
        if ("requestIdleCallback" in window) {
          requestIdleCallback(loadMetrika, { timeout: 4000 });
        } else {
          setTimeout(loadMetrika, 2000);
        }
      }

      if (document.readyState === "complete") {
        deferMetrika();
      } else {
        window.addEventListener("load", deferMetrika);
      }
    </script>
    <noscript
      ><div>
        <img
          src="https://mc.yandex.ru/watch/110118475"
          style="position:absolute; left:-9999px;"
          alt=""
        />
      </div></noscript
    >
    <!-- /Yandex.Metrika counter -->

    <slot />
  </body>
</html>
