---
import '../index.css'
import { ClientRouter } from 'astro:transitions'

export interface Props {
  /** Page locale. */
  locale: 'en' | 'ru'
  /** Document <title>. */
  title: string
  /** Meta description. */
  description: string
  /** Locale-neutral path (no /ru prefix, leading slash), e.g. "/", "/privacy". */
  path: string
}

const { locale, title, description, path } = Astro.props

const SITE = 'https://alisie.app'

// Build canonical + hreflang alternates from the locale-neutral path.
const enHref = path === '/' ? `${SITE}/` : `${SITE}${path}`
const ruHref = path === '/' ? `${SITE}/ru` : `${SITE}/ru${path}`
const canonical = locale === 'ru' ? ruHref : enHref
const ogLocale = locale === 'ru' ? 'ru_RU' : 'en_US'
const ogLocaleAlt = locale === 'ru' ? 'en_US' : 'ru_RU'
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <ClientRouter />
    <link rel="preload" as="image" href="/app_icon_192.png" />
    <!-- iOS Safari Smart App Banner - native "Open in App" prompt -->
    <meta name="apple-itunes-app" content="app-id=1485091289" />

    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="dream journal, dream diary, lucid dreaming, dream tracker, iOS, iPhone, iPad, Alisie"
    />
    <link rel="canonical" href={canonical} />

    <!-- Language alternates -->
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="ru" href={ruHref} />
    <link rel="alternate" hreflang="x-default" href={enHref} />

    <!-- Open Graph (Facebook, Telegram, VK, LinkedIn) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Alisie" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${SITE}/app_icon.png`} />
    <meta property="og:image:alt" content="Alisie app icon" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${SITE}/app_icon.png`} />

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair:ital,wght@1,700&family=Sora:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <!-- Set the theme before first paint to avoid a flash of the wrong theme.
         Re-runs after each View Transition swap so navigation never flashes. -->
    <script is:inline>
      function applyTheme() {
        try {
          var saved = localStorage.getItem('theme')
          var theme = saved === 'light' ? 'light' : 'dark'
          document.documentElement.classList.remove('theme-light', 'theme-dark')
          document.documentElement.classList.add('theme-' + theme)
        } catch (e) {
          document.documentElement.classList.add('theme-dark')
        }
      }
      applyTheme()
      document.addEventListener('astro:after-swap', applyTheme)
    </script>
  </head>
  <body>
    <!-- Yandex.Metrika counter -->
    <script type="text/javascript" is:inline>
      ;(function (m, e, t, r, i, k, a) {
        m[i] =
          m[i] ||
          function () {
            ;(m[i].a = m[i].a || []).push(arguments)
          }
        m[i].l = 1 * new Date()
        for (var j = 0; j < document.scripts.length; j++) {
          if (document.scripts[j].src === r) {
            return
          }
        }
        ;(k = e.createElement(t)),
          (a = e.getElementsByTagName(t)[0]),
          (k.async = 1),
          (k.src = r),
          a.parentNode.insertBefore(k, a)
      })(
        window,
        document,
        'script',
        'https://mc.yandex.ru/metrika/tag.js?id=110118475',
        'ym'
      )

      ym(110118475, 'init', {
        ssr: true,
        clickmap: true,
        ecommerce: 'dataLayer',
        referrer: document.referrer,
        url: location.href,
        accurateTrackBounce: true,
        trackLinks: true,
      })
    </script>
    <noscript
      ><div>
        <img
          src="https://mc.yandex.ru/watch/110118475"
          style="position:absolute; left:-9999px;"
          alt=""
        />
      </div></noscript
    >
    <!-- /Yandex.Metrika counter -->

    <slot />
  </body>
</html>
